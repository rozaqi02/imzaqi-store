# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── dependencies ─────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.js

# ── testing ──────────────────────────────────────────────────────
/coverage

# ── production / build artifacts ─────────────────────────────────
/build
/build-temp
/build-verify-*
*.tsbuildinfo

# ── env files ────────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── logs ─────────────────────────────────────────────────────────
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── caches ───────────────────────────────────────────────────────
.eslintcache
.cache
.parcel-cache
.next
.turbo

# ── editor / IDE ─────────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
.idea
*.swp
*.swo
*~

# ── OS files ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# ── deployment / local tooling ───────────────────────────────────
.netlify
.vercel
.firebase
*.local

# ── Kiro internal specs ──────────────────────────────────────────
.kiro/
